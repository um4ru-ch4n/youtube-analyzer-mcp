# Transport mode: stdio (default) or http
TRANSPORT_MODE=stdio

# HTTP port (used when TRANSPORT_MODE=http)
HTTP_PORT=3000

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Application environment: development or production
APP_ENV=development

# Vision provider API keys (only one needed, depends on vision.provider in config.yaml)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
